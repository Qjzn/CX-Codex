{
  "name": "cx-codex",
  "version": "2.3.0",
  "description": "CX-Codex Web UI and browser bridge for Windows, Linux, Android, LAN, and remote self-hosted access",
  "type": "module",
  "license": "MIT",
  "author": "Pavel Voronin, Igor Levochkin, and contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qjzn/CX-Codex.git"
  },
  "homepage": "https://github.com/Qjzn/CX-Codex#readme",
  "bugs": {
    "url": "https://github.com/Qjzn/CX-Codex/issues"
  },
  "keywords": [
    "codex",
    "openai",
    "openai-codex",
    "codex-ui",
    "codex-web",
    "web-ui",
    "browser-ui",
    "remote",
    "remote-access",
    "self-hosted",
    "windows",
    "windows-server",
    "linux",
    "android",
    "termux",
    "lan",
    "cli",
    "mobile-browser",
    "cloudflare-tunnel",
    "self-hosted-codex",
    "windows-friendly",
    "remote-development",
    "ai-coding-agent"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "cx-codex": "dist-cli/index.js",
    "cxcodex": "dist-cli/index.js"
  },
  "files": [
    "dist/",
    "dist-cli/",
    "docs/app-server-schema-audit-summary.json"
  ],
  "scripts": {
    "dev": "vite",
    "build:frontend": "vue-tsc --noEmit && vite build",
    "build:cli": "tsup",
    "build": "npm run build:frontend && npm run build:cli",
    "mobile:android:add": "npx cap add android",
    "mobile:android:sync": "npm run build:frontend && npx cap sync android",
    "mobile:android:open": "npx cap open android",
    "mobile:android:run": "npm run mobile:android:sync && npx cap run android",
    "package:release": "node ./scripts/run-powershell-script.mjs ./scripts/package-release.ps1",
    "setup:windows": "node ./scripts/run-powershell-script.mjs ./setup.ps1",
    "test:7420": "node ./scripts/run-powershell-script.mjs ./scripts/regression-7420.ps1",
    "test:7420:frontend": "node ./scripts/run-powershell-script.mjs ./scripts/regression-7420-frontend.ps1",
    "test:7420:sidebar-data": "node ./scripts/verify-7420-sidebar-data.mjs",
    "test:7420:soak": "node ./scripts/run-powershell-script.mjs ./scripts/soak-7420.ps1",
    "audit:app-server-schemas": "node ./scripts/run-powershell-script.mjs ./scripts/audit-app-server-schemas.ps1",
    "audit:app-server-schemas:update-summary": "node ./scripts/update-app-server-schema-audit-summary.mjs",
    "verify:governance": "node ./scripts/run-powershell-script.mjs ./scripts/verify-governance.ps1",
    "verify:frontend-normalizers": "node ./scripts/verify-frontend-normalizers.mjs",
    "verify:server-modules": "node ./scripts/verify-server-modules.mjs",
    "verify:release": "node ./scripts/run-powershell-script.mjs ./scripts/verify-release.ps1",
    "verify:release-artifacts": "node ./scripts/run-powershell-script.mjs ./scripts/verify-release-artifacts.ps1",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.7",
    "express": "^5.1.0",
    "markdown-it": "^14.2.0",
    "pdfjs-dist": "^5.7.284",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "esbuild": "^0.27.7",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.2.0"
  }
}
